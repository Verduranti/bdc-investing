# BDC Stress Radar — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL: Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key (NOT the anon key) — bypasses RLS so the ETL can write freely.
# Settings → API → Project API keys → service_role
SUPABASE_SERVICE_KEY=eyJ...

# ── EDGAR ─────────────────────────────────────────────────────────────────────
# SEC requires your email in the User-Agent header for EDGAR API requests.
# Use your real address — they only contact you if there's a problem.
EDGAR_EMAIL=your@email.com

# ── Vite / Frontend ───────────────────────────────────────────────────────────
# Public Supabase config for the React app (safe to expose — used by Vite).
# Settings → API → Project URL and anon/public key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
